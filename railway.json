{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "buildCommand": "composer install",
        "dockerfilePath": "Dockerfile"
    },
    "deploy": {
        "runtime": "V2",
        "numReplicas": 1,
        "startCommand": "php artisan migrate:fresh --seed --force && php artisan config:cache && php artisan route:cache && php artisan serve --host 0.0.0.0 --port $PORT",
        "sleepApplication": false,
        "useLegacyStacker": false,
        "ipv6EgressEnabled": false,
        "multiRegionConfig": {
            "us-west2": {
                "numReplicas": 1
            }
        },
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
